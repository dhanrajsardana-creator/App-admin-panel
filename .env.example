# ─── CMS API ────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=https://stage-api.powerlook.in/api/v1/
VITE_API_TIMEOUT=30000
# Send the ngrok interstitial-bypass header (set false for non-ngrok hosts)
VITE_NGROK_SKIP_WARNING=true

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Backend OAuth entry point, relative to VITE_API_BASE_URL
VITE_AUTH_LOGIN_PATH=/auth/shopify
# localStorage key the JWT is stored under
VITE_TOKEN_STORAGE_KEY=cms_admin_token

# ─── Branding ─────────────────────────────────────────────────────────────────
VITE_APP_NAME=Mobile App Builder
VITE_STORE_BRAND_NAME=POWERLOOK

# ─── Defaults ─────────────────────────────────────────────────────────────────
# pageKey auto-selected when the builder first loads
VITE_DEFAULT_PAGE_KEY=HOME_PAGE

# ─── Shopify (SERVER-SIDE ONLY — no VITE_ prefix, never sent to the browser) ──
# Used only by the Vite dev-server proxy (vite.config.ts). In production the CMS
# backend must proxy Shopify — this Admin token must never reach client code.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_API_VERSION=2025-07
SHOPIFY_ADMIN_TOKEN=shpca_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_SHOPIFY_ENABLED=true
